{
  "name": "@ezorm/proxy-node",
  "version": "1.1.1",
  "description": "Server-side lifecycle management for the Ezorm Rust proxy.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thachp/ezorm"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@ezorm/proxy-bin-aarch64-apple-darwin": "1.1.1",
    "@ezorm/proxy-bin-x86_64-apple-darwin": "1.1.1",
    "@ezorm/proxy-bin-x86_64-pc-windows-msvc": "1.1.1",
    "@ezorm/proxy-bin-x86_64-unknown-linux-gnu": "1.1.1"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
