{
  "name": "@ezorm/next",
  "version": "1.1.2",
  "description": "Next.js adapters for direct Ezorm node clients and proxy-backed edge clients.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thachp/ezorm"
  },
  "type": "module",
  "dependencies": {
    "@ezorm/orm": "1.1.2",
    "@ezorm/proxy-node": "1.1.2",
    "@ezorm/runtime-node": "1.1.2",
    "@ezorm/runtime-proxy": "1.1.2"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.js",
      "default": "./dist/edge.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
