{
  "name": "@ezorm/runtime-node",
  "version": "1.1.1",
  "description": "Direct Node.js runtime helper for Ezorm SQLite ORM flows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thachp/ezorm"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ezorm/orm": "1.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
