{
  "name": "ezorm",
  "version": "0.1.0",
  "description": "Ezorm CLI for migrations and database workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ezorm": "./bin/ezorm.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "prepack": "pnpm run build"
  }
}
