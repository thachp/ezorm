{
  "name": "ezorm",
  "version": "1.1.2",
  "description": "Ezorm CLI for migrations and database workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thachp/ezorm"
  },
  "type": "module",
  "bin": {
    "ezorm": "./bin/ezorm.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ezorm/core": "1.1.2",
    "@ezorm/orm": "1.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
