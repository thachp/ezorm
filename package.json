{
  "name": "sqlmodel-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.15.7",
  "scripts": {
    "build": "pnpm build:ts && pnpm build:native",
    "build:native": "node packages/runtime-node/scripts/build-native.mjs --release",
    "build:native:debug": "node packages/runtime-node/scripts/build-native.mjs",
    "build:sqlmod": "pnpm --dir packages/cli run build",
    "build:ts": "tsc -p tsconfig.json",
    "pack:sqlmod": "node ./scripts/pack-sqlmod.mjs",
    "release:sqlmod": "node ./scripts/release-sqlmod.mjs",
    "smoke:sqlmod": "node ./scripts/smoke-sqlmod-package.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ts": "vitest run",
    "test": "pnpm test:ts && cargo test"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
